# Airtable
AIRTABLE_PAT=patxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID_SHOPPING=appxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID_RECIPES=appxxxxxxxxxxxxxxxx

# Tablas Personal Planner (nombres exactos como en tu base)
AIRTABLE_TABLE_OBJECTIVES=Objectives
AIRTABLE_TABLE_KEY_RESULTS=Key Results
AIRTABLE_TABLE_TASKS=Tasks
AIRTABLE_TABLE_HABITS=Habits
AIRTABLE_TABLE_HABIT_TRACKING=Habit Tracking
AIRTABLE_TABLE_KEY_RESULT_TRACKING=Key Results Tracking
AIRTABLE_TABLE_SHOPPING=Shopping List
AIRTABLE_TABLE_MEALS=Meals
AIRTABLE_TABLE_DISCOVERY=Discovery Ideas

# Tablas Recipes (base separada; usa AIRTABLE_BASE_ID_RECIPES)
