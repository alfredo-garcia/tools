AIRTABLE_TABLE_INGREDIENTS=Ingredients
AIRTABLE_TABLE_RECIPE_INGREDIENTS=Recipe Ingredients

# Google Calendar (opcional). Redirect URI: si no se setea, en dev se usa http://localhost:5173/api/calendar/oauth-callback cuando la API corre en 3000.
